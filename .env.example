# Environment variables for production
# Copy this file to .env and fill in your values
# On PythonAnywhere, set these in the Web tab -> Environment variables

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourusername.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Optional: Cloudinary for image uploads (get from cloudinary.com dashboard)
# Without this, images are stored locally under /media/
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
